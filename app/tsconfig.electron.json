{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist-electron",
    "declaration": false,
    "noEmit": false,
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@koinara/shared": ["../shared/dist/index.d.ts"],
      "@koinara/shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["electron"]
}
